<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Disabled + Checked (muted ON track) -->
    <item
        android:state_enabled="false"
        android:state_checked="true"
        android:color="#2D4A2D" />

    <!-- Disabled + Unchecked (muted OFF track) -->
    <item
        android:state_enabled="false"
        android:state_checked="false"
        android:color="#3A3A3A" />

    <!-- Enabled + Checked (soft primary) -->
    <item
        android:state_checked="true"
        android:color="#6681C784" />

    <!-- Enabled + Unchecked -->
    <item android:color="#4A4A4A" />

</selector>
